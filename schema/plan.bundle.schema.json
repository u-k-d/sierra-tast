{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/sierra-research-engine/plan.bundle.sierra_runtime.v2_6_2.json",
  "title": "Sierra Research Engine Plan Bundle (Sierra Runtime) v2.6.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "plan_kind",
    "plan_io",
    "universe",
    "execution",
    "studies",
    "chains",
    "outputs"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 262
    },
    "plan_kind": {
      "type": "string",
      "const": "sierra_research_engine.plan"
    },
    "plan_io": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format"
      ],
      "properties": {
        "format": {
          "type": "string",
          "enum": [
            "json"
          ]
        },
        "encoding": {
          "type": "string",
          "enum": [
            "utf-8"
          ],
          "default": "utf-8"
        },
        "allow_comments": {
          "type": "boolean",
          "default": false
        },
        "max_bytes": {
          "type": "integer",
          "minimum": 1024,
          "default": 500000
        }
      }
    },
    "compat": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "extensions": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "default": []
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "default": {},
      "properties": {
        "require_refs_resolve": {
          "type": "boolean",
          "default": true
        },
        "require_gates_exist": {
          "type": "boolean",
          "default": true
        },
        "require_studies_exist": {
          "type": "boolean",
          "default": true
        },
        "require_sierra_readiness_contract": {
          "type": "boolean",
          "default": true
        },
        "prefer_typed_step_io_refs": {
          "type": "boolean",
          "default": true
        },
        "sierra_study_input_permute_policy": {
          "type": "string",
          "enum": [
            "managed_only",
            "allowlist_bind_mode",
            "disabled"
          ],
          "default": "managed_only"
        },
        "sierra_study_input_permute_on_violation": {
          "type": "string",
          "enum": [
            "error",
            "warn",
            "skip_permutation"
          ],
          "default": "error"
        },
        "sierra_bind_mode_allowlist": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "study_key"
            ],
            "properties": {
              "study_key": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_]{0,63}$"
              },
              "method": {
                "type": "string",
                "enum": [
                  "native_setter",
                  "managed_bridge"
                ],
                "default": "native_setter"
              },
              "inputs_allow": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_]{0,63}$"
                },
                "default": []
              }
            }
          }
        }
      }
    },
    "universe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "inline",
            "file"
          ]
        },
        "symbols": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "file": {
          "type": "object"
        },
        "timeframe": {
          "type": "string",
          "pattern": "^[0-9]+(s|m|h|d|w)$"
        },
        "date_range": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "start",
            "end"
          ],
          "properties": {
            "start": {
              "type": "string",
              "format": "date"
            },
            "end": {
              "type": "string",
              "format": "date"
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "source": {
                "const": "inline"
              }
            }
          },
          "then": {
            "required": [
              "symbols"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "source": {
                "const": "file"
              }
            }
          },
          "then": {
            "required": [
              "file"
            ]
          }
        }
      ]
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "worker_charts",
        "backend"
      ],
      "properties": {
        "controller_chart": {
          "type": "integer",
          "minimum": 1
        },
        "worker_charts": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          },
          "minItems": 1
        },
        "permissions": {
          "type": "object",
          "additionalProperties": false,
          "default": {},
          "properties": {
            "allow_filesystem_write": {
              "type": "boolean",
              "default": false
            },
            "allow_network": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "sentinel": {
          "type": "object",
          "additionalProperties": false,
          "default": {},
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "study_id": {
              "type": "integer",
              "minimum": 1
            },
            "subgraph": {
              "type": "integer",
              "minimum": 0
            },
            "slot": {
              "type": "integer",
              "minimum": 0,
              "default": 9
            },
            "ready_value": {
              "type": "number",
              "default": 1.0
            },
            "timeout_cycles": {
              "type": "integer",
              "minimum": 1,
              "default": 30
            }
          }
        },
        "backend": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "sierra_chart"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "sierra_chart"
              ],
              "default": "sierra_chart"
            },
            "sierra_chart": {
              "type": "object",
              "additionalProperties": false,
              "default": {},
              "properties": {
                "scheduler_mode": {
                  "type": "string",
                  "enum": [
                    "serial",
                    "worker_pool"
                  ],
                  "default": "serial"
                },
                "layout_contract": {
                  "type": "object",
                  "additionalProperties": false,
                  "default": {},
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "default": true
                    },
                    "controller_chart": {
                      "type": "integer",
                      "minimum": 1
                    },
                    "workers": {
                      "type": "array",
                      "default": [],
                      "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": [
                          "chart_number"
                        ],
                        "properties": {
                          "chart_number": {
                            "type": "integer",
                            "minimum": 1
                          },
                          "required_studies": {
                            "type": "array",
                            "default": [],
                            "items": {
                              "type": "object",
                              "additionalProperties": false,
                              "required": [
                                "study_key"
                              ],
                              "properties": {
                                "study_key": {
                                  "type": "string",
                                  "pattern": "^[a-z][a-z0-9_]{0,63}$"
                                },
                                "require_outputs": {
                                  "type": "array",
                                  "items": {
                                    "type": "string"
                                  },
                                  "default": []
                                }
                              }
                            }
                          }
                        }
                      }
                    },
                    "readiness": {
                      "type": "object",
                      "additionalProperties": false,
                      "default": {
                        "mode": "sentinel"
                      },
                      "properties": {
                        "mode": {
                          "type": "string",
                          "enum": [
                            "sentinel",
                            "gate"
                          ],
                          "default": "sentinel"
                        },
                        "ready_gate": {
                          "type": "string",
                          "pattern": "^@gate\\.[a-z][a-z0-9_]{0,63}$"
                        }
                      },
                      "allOf": [
                        {
                          "if": {
                            "properties": {
                              "mode": {
                                "const": "gate"
                              }
                            }
                          },
                          "then": {
                            "required": [
                              "ready_gate"
                            ]
                          }
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "layer2": {
          "$ref": "#/$defs/Layer2Execution"
        }
      }
    },
    "studies": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "mode",
          "study_id",
          "outputs"
        ],
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "bind",
              "managed"
            ]
          },
          "chart_ref": {
            "type": "string",
            "enum": [
              "worker",
              "controller"
            ],
            "default": "worker"
          },
          "study_id": {
            "type": "integer",
            "minimum": 1
          },
          "study_name_hint": {
            "type": "string"
          },
          "inputs": {
            "type": "object",
            "additionalProperties": true,
            "default": {}
          },
          "outputs": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "subgraph"
              ],
              "properties": {
                "subgraph": {
                  "type": "integer",
                  "minimum": 0
                },
                "field": {
                  "type": "string",
                  "enum": [
                    "value"
                  ],
                  "default": "value"
                }
              }
            }
          }
        }
      }
    },
    "signals": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "gates": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "parameters": {
      "type": "object",
      "additionalProperties": false,
      "default": {},
      "properties": {
        "constants": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        },
        "permute": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "kind",
              "values"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "study_input",
                  "rule_param",
                  "symbol"
                ]
              },
              "study": {
                "type": "string"
              },
              "input": {
                "type": "string"
              },
              "requires_study_mode": {
                "type": "string",
                "enum": [
                  "managed",
                  "bind"
                ],
                "default": "managed"
              },
              "binding_method_hint": {
                "type": "string",
                "enum": [
                  "native_setter",
                  "managed_bridge"
                ],
                "default": "native_setter"
              },
              "target": {
                "type": "string"
              },
              "param_path": {
                "type": "string"
              },
              "values": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": [
                    "number",
                    "integer",
                    "boolean",
                    "string"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "dag": {
      "type": [
        "object",
        "null"
      ],
      "default": null
    },
    "chains": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "steps"
        ],
        "properties": {
          "description": {
            "type": "string"
          },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object"
            }
          }
        }
      }
    },
    "edge_eval": {
      "type": [
        "object",
        "null"
      ],
      "default": null
    },
    "outcome_model": {
      "type": [
        "object",
        "null"
      ],
      "default": null
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataset"
      ],
      "properties": {
        "dataset": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "format",
            "path",
            "fields"
          ],
          "properties": {
            "format": {
              "type": "string",
              "enum": [
                "csv",
                "jsonl"
              ],
              "default": "csv"
            },
            "path": {
              "type": "string",
              "minLength": 1
            },
            "fields": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object"
              }
            },
            "source": {
              "type": "string",
              "enum": [
                "bars",
                "layer2_event_emitter"
              ],
              "default": "bars",
              "description": "Selects what the dataset writer emits. 'bars' uses field refs (legacy). 'layer2_event_emitter' uses execution.layer2.event_emitter rows."
            }
          }
        },
        "artifacts": {
          "type": "object",
          "additionalProperties": false,
          "default": {},
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "base_dir": {
              "type": "string",
              "default": "artifacts"
            },
            "write_run_manifest": {
              "type": "boolean",
              "default": true
            },
            "write_metrics_summary": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "layer3": {
          "$ref": "#/$defs/Layer3Augmentation"
        }
      }
    }
  },
  "$defs": {
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "Percentile": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "QuantileList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Percentile"
      },
      "minItems": 1
    },
    "Bool": {
      "type": "boolean"
    },
    "Layer2ParamNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "type",
        "value"
      ],
      "properties": {
        "kind": {
          "const": "param"
        },
        "type": {
          "enum": [
            "float",
            "int",
            "bool",
            "string"
          ]
        },
        "value": {}
      }
    },
    "Layer2BarFieldNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "field"
      ],
      "properties": {
        "kind": {
          "const": "bar_field"
        },
        "field": {
          "enum": [
            "open",
            "high",
            "low",
            "close",
            "volume",
            "vwap",
            "datetime"
          ]
        },
        "lag_bars": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      }
    },
    "Layer2StudyRefNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref"
      ],
      "properties": {
        "kind": {
          "const": "study_ref"
        },
        "ref": {
          "type": "string",
          "pattern": "^@study\\.[A-Za-z0-9_\\-]+\\.[A-Za-z0-9_\\-]+$"
        },
        "lag_bars": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      }
    },
    "Layer2OpNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "inputs"
      ],
      "properties": {
        "kind": {
          "enum": [
            "sma",
            "ema",
            "atr",
            "roc",
            "diff",
            "add",
            "sub",
            "mul",
            "div",
            "gt",
            "gte",
            "lt",
            "lte",
            "eq",
            "neq",
            "and",
            "or",
            "not",
            "abs",
            "clip"
          ]
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NonEmptyString"
          },
          "minItems": 1
        },
        "window_bars": {
          "type": "integer",
          "minimum": 1
        },
        "min_warmup_bars": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "params": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "Layer2Node": {
      "oneOf": [
        {
          "$ref": "#/$defs/Layer2ParamNode"
        },
        {
          "$ref": "#/$defs/Layer2BarFieldNode"
        },
        {
          "$ref": "#/$defs/Layer2StudyRefNode"
        },
        {
          "$ref": "#/$defs/Layer2OpNode"
        }
      ]
    },
    "Layer2Dag": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nodes"
      ],
      "properties": {
        "nodes": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/Layer2Node"
          }
        }
      }
    },
    "Layer2EmitColumn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "type": {
          "enum": [
            "string",
            "datetime",
            "float",
            "int",
            "bool"
          ]
        },
        "nullable": {
          "type": "boolean",
          "default": false
        },
        "ref": {
          "type": "string"
        },
        "node": {
          "$ref": "#/$defs/NonEmptyString"
        }
      },
      "anyOf": [
        {
          "required": [
            "ref"
          ]
        },
        {
          "required": [
            "node"
          ]
        }
      ]
    },
    "Layer2EventEmitter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger_node",
        "emit_mode",
        "emit_columns"
      ],
      "properties": {
        "trigger_node": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "emit_mode": {
          "enum": [
            "on_true_edge",
            "on_true"
          ],
          "default": "on_true_edge"
        },
        "cooldown_bars": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "emit_columns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Layer2EmitColumn"
          },
          "minItems": 1
        }
      }
    },
    "Layer2Execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "mode",
        "indicator_dag",
        "event_emitter"
      ],
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "mode": {
          "enum": [
            "authoritative_events"
          ],
          "default": "authoritative_events"
        },
        "bar_basis": {
          "enum": [
            "close",
            "open",
            "intrabar"
          ],
          "default": "close"
        },
        "require_final_bar": {
          "type": "boolean",
          "default": true
        },
        "align": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "enum": [
                "last_completed",
                "strict_close"
              ],
              "default": "last_completed"
            }
          },
          "default": {
            "mode": "last_completed"
          }
        },
        "indicator_dag": {
          "$ref": "#/$defs/Layer2Dag"
        },
        "event_emitter": {
          "$ref": "#/$defs/Layer2EventEmitter"
        }
      }
    },
    "BucketRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "scope",
        "field",
        "op"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "scope": {
          "enum": [
            "bucket",
            "rr_row",
            "event"
          ]
        },
        "field": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "op": {
          "enum": [
            ">",
            ">=",
            "<",
            "<=",
            "==",
            "!=",
            "not_null",
            "is_null"
          ]
        },
        "value": {}
      }
    },
    "QuantileSampleGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "q",
        "min_n"
      ],
      "properties": {
        "q": {
          "$ref": "#/$defs/Percentile"
        },
        "min_n": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "Layer3BucketingDimension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "method",
        "q"
      ],
      "properties": {
        "field": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "method": {
          "enum": [
            "quantile"
          ],
          "default": "quantile"
        },
        "q": {
          "$ref": "#/$defs/QuantileList"
        },
        "distribution": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "scope": {
              "enum": [
                "event_sample",
                "all_bars",
                "rolling_time",
                "per_symbol"
              ],
              "default": "event_sample"
            },
            "window_days": {
              "type": "integer",
              "minimum": 1
            },
            "min_samples": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "Layer3OutcomesSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "entry_price_field",
        "horizon",
        "price_fields",
        "cost_model"
      ],
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "entry_price_field": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "horizon": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ],
          "properties": {
            "type": {
              "enum": [
                "bars"
              ]
            },
            "value": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "price_fields": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "high",
            "low",
            "close"
          ],
          "properties": {
            "high": {
              "type": "string"
            },
            "low": {
              "type": "string"
            },
            "close": {
              "type": "string"
            }
          }
        },
        "compute": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mfe": {
              "type": "object",
              "additionalProperties": true
            },
            "mfa": {
              "type": "object",
              "additionalProperties": true
            },
            "ret": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "default": {
            "mfe": {
              "kind": "max_high_over_horizon"
            },
            "mfa": {
              "kind": "min_low_over_horizon"
            },
            "ret": {
              "kind": "close_at_horizon"
            }
          }
        },
        "cost_model": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "enum": [
                "none",
                "fixed_bps"
              ],
              "default": "none"
            },
            "bps": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "Layer3MetricsSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "per_bucket": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "emit": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/NonEmptyString"
              },
              "minItems": 1
            }
          }
        }
      }
    },
    "Layer3Augmentation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "mode",
        "inputs",
        "eligibility",
        "artifacts"
      ],
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "mode": {
          "enum": [
            "rr_menu",
            "bucket_eval"
          ],
          "default": "rr_menu"
        },
        "inputs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "layer2_authoritative_csv"
          ],
          "properties": {
