              "type": "string"
            }
          }
        },
        "eligibility": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "emit_for_all_eligible_buckets": {
              "type": "boolean",
              "default": true
            },
            "rules": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/BucketRule"
              },
              "default": []
            },
            "quantile_sample_gates": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/QuantileSampleGate"
              },
              "default": []
            }
          },
          "default": {}
        },
        "rr_menu": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "risk_quantiles": {
              "$ref": "#/$defs/QuantileList"
            },
            "reward_quantiles": {
              "$ref": "#/$defs/QuantileList"
            },
            "pairing": {
              "enum": [
                "cartesian",
                "zip"
              ],
              "default": "cartesian"
            },
            "row_rules": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/BucketRule"
              },
              "default": []
            }
          }
        },
        "normalization": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "enum": [
                "pct_of_price",
                "raw"
              ],
              "default": "pct_of_price"
            },
            "entry_price_field": {
              "$ref": "#/$defs/NonEmptyString"
            },
            "emit_raw_price_columns": {
              "type": "boolean",
              "default": true
            },
            "emit_pct_columns": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "units_contract": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "signal_bucket_units": {
              "$ref": "#/$defs/NonEmptyString"
            },
            "mae_units": {
              "enum": [
                "price",
                "pct"
              ],
              "default": "price"
            },
            "mfe_units": {
              "enum": [
                "price",
                "pct"
              ],
              "default": "price"
            },
            "enforce_no_bucket_clamp": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "signals": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "sma50_field": {
              "$ref": "#/$defs/NonEmptyString"
            },
            "rvol_field": {
              "$ref": "#/$defs/NonEmptyString"
            }
          }
        },
        "bucketing": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dimensions": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Layer3BucketingDimension"
              },
              "minItems": 1
            }
          }
        },
        "outcomes": {
          "$ref": "#/$defs/Layer3OutcomesSpec"
        },
        "metrics": {
          "$ref": "#/$defs/Layer3MetricsSpec"
        },
        "artifacts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "rr_buckets",
            "decision_audit"
          ],
          "properties": {
            "rr_buckets": {
              "type": "string"
            },
            "decision_audit": {
              "type": "string"
            },
            "outcomes_per_event": {
              "type": "string"
            },
            "bucket_stats": {
              "type": "string"
            }
          }
        }
      }
    }
  }
