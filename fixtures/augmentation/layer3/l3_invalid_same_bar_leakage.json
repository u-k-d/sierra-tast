{
  "version": 262,
  "plan_kind": "sierra_research_engine.plan",
  "plan_io": {
    "format": "json"
  },
  "universe": {
    "source": "inline",
    "symbols": [
      "ES"
    ]
  },
  "execution": {
    "worker_charts": [
      2
    ],
    "permissions": {
      "allow_filesystem_write": true
    },
    "backend": {
      "type": "sierra_chart",
      "sierra_chart": {}
    },
    "layer2": {
      "enabled": true,
      "mode": "authoritative_events",
      "indicator_dag": {
        "nodes": {
          "always_true": {
            "kind": "param",
            "type": "bool",
            "value": true
          }
        }
      },
      "event_emitter": {
        "trigger_node": "always_true",
        "emit_mode": "on_true",
        "cooldown_bars": 1,
        "emit_columns": [
          {
            "name": "entry_price",
            "type": "float",
            "ref": "@bar.close"
          }
        ]
      }
    }
  },
  "studies": {
    "ema_fast": {
      "mode": "managed",
      "study_id": 1,
      "outputs": {
        "value": {
          "subgraph": 0
        }
      }
    }
  },
  "chains": {
    "main": {
      "steps": [
        {
          "kind": "emit",
          "from": "@study.ema_fast.value",
          "as": "ema"
        }
      ]
    }
  },
  "outputs": {
    "dataset": {
      "format": "csv",
      "path": "__TMP__/layer3_invalid/{symbol}/authoritative.csv",
      "source": "layer2_event_emitter",
      "fields": [
        {
          "name": "symbol",
          "ref": "@event.symbol"
        },
        {
          "name": "bar_index",
          "ref": "@event.bar_index"
        },
        {
          "name": "entry_price",
          "ref": "@event.entry_price"
        }
      ]
    },
    "layer3": {
      "enabled": true,
      "mode": "bucket_eval",
      "inputs": {
        "layer2_authoritative_csv": "__TMP__/layer3_invalid/{symbol}/authoritative.csv"
      },
      "eligibility": {},
      "outcomes": {
        "enabled": true,
        "entry_price_field": "entry_price",
        "horizon": {
          "type": "bars",
          "value": 3
        },
        "price_fields": {
          "high": "high",
          "low": "low",
          "close": "close"
        },
        "compute": {
          "mfe": {
            "kind": "max_high_same_bar"
          }
        },
        "cost_model": {
          "type": "none"
        }
      },
      "artifacts": {
        "rr_buckets": "__TMP__/layer3_invalid/{symbol}/rr_unused.csv",
        "decision_audit": "__TMP__/layer3_invalid/{symbol}/audit_unused.csv",
        "outcomes_per_event": "__TMP__/layer3_invalid/{symbol}/outcomes_per_event.csv",
        "bucket_stats": "__TMP__/layer3_invalid/{symbol}/bucket_stats.csv"
      }
    },
    "artifacts": {
      "enabled": true,
      "base_dir": "__TMP__/meta",
      "write_run_manifest": true,
      "write_metrics_summary": true
    }
  },
  "meta": {
    "fixture_id": "augmentation_l3_invalid_same_bar"
  }
}
