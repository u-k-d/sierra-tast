{
  "version": 262,
  "plan_kind": "sierra_research_engine.plan",
  "plan_io": {
    "format": "json"
  },
  "universe": {
    "source": "inline",
    "symbols": [
      "ES",
      "NQ"
    ],
    "date_range": {
      "start": "2025-01-01",
      "end": "2025-01-01"
    }
  },
  "execution": {
    "worker_charts": [
      2
    ],
    "permissions": {
      "allow_filesystem_write": true
    },
    "backend": {
      "type": "sierra_chart",
      "sierra_chart": {}
    },
    "layer2": {
      "enabled": true,
      "mode": "authoritative_events",
      "require_final_bar": true,
      "align": {
        "mode": "last_completed"
      },
      "indicator_dag": {
        "nodes": {
          "close_n": {
            "kind": "bar_field",
            "field": "close"
          },
          "anchor_n": {
            "kind": "param",
            "type": "float",
            "value": 80.0
          },
          "rvol_n": {
            "kind": "diff",
            "inputs": [
              "close_n",
              "anchor_n"
            ]
          },
          "always_true": {
            "kind": "param",
            "type": "bool",
            "value": true
          },
          "trigger_n": {
            "kind": "and",
            "inputs": [
              "always_true",
              "always_true"
            ]
          }
        }
      },
      "event_emitter": {
        "trigger_node": "trigger_n",
        "emit_mode": "on_true",
        "cooldown_bars": 4,
        "emit_columns": [
          {
            "name": "entry_price",
            "type": "float",
            "ref": "@bar.close"
          },
          {
            "name": "rvol",
            "type": "float",
            "node": "rvol_n"
          },
          {
            "name": "bar_datetime",
            "type": "datetime",
            "ref": "@bar.datetime"
          }
        ]
      }
    }
  },
  "studies": {
    "ema_fast": {
      "mode": "managed",
      "study_id": 1,
      "outputs": {
        "value": {
          "subgraph": 0
        }
      }
    }
  },
  "chains": {
    "main": {
      "steps": [
        {
          "kind": "emit",
          "from": "@study.ema_fast.value",
          "as": "ema"
        }
      ]
    }
  },
  "outputs": {
    "dataset": {
      "format": "csv",
      "path": "__TMP__/layer3/{symbol}/authoritative.csv",
      "source": "layer2_event_emitter",
      "fields": [
        {
          "name": "symbol",
          "ref": "@event.symbol"
        },
        {
          "name": "bar_index",
          "ref": "@event.bar_index"
        },
        {
          "name": "entry_price",
          "ref": "@event.entry_price"
        },
        {
          "name": "rvol",
          "ref": "@event.rvol"
        },
        {
          "name": "bar_datetime",
          "ref": "@event.bar_datetime"
        }
      ]
    },
    "layer3": {
      "enabled": true,
      "mode": "bucket_eval",
      "inputs": {
        "layer2_authoritative_csv": "__TMP__/layer3/{symbol}/authoritative.csv"
      },
      "eligibility": {
        "rules": [
          {
            "id": "min_trades",
            "scope": "bucket",
            "field": "n_trades",
            "op": ">=",
            "value": 1
          },
          {
            "id": "ev_floor",
            "scope": "bucket",
            "field": "EV",
            "op": ">",
            "value": -1.0
          }
        ]
      },
      "bucketing": {
        "dimensions": [
          {
            "field": "rvol",
            "method": "quantile",
            "q": [
              0.25,
              0.5,
              0.75
            ]
          }
        ]
      },
      "outcomes": {
        "enabled": true,
        "entry_price_field": "entry_price",
        "horizons_bars": [
          5,
          10,
          15,
          20
        ],
        "sides": [
          "long",
          "short"
        ],
        "price_fields": {
          "high": "high",
          "low": "low",
          "close": "close"
        },
        "cost_model": {
          "type": "fixed_bps",
          "bps": 2.0
        }
      },
      "metrics": {
        "per_bucket": {
          "emit": [
            "n_trades",
            "EV",
            "mfe_p50",
            "mfa_p50"
          ]
        }
      },
      "artifacts": {
        "rr_buckets": "__TMP__/layer3/{symbol}/rr_unused.csv",
        "decision_audit": "__TMP__/layer3/{symbol}/decision_audit.csv",
        "outcomes_per_event": "__TMP__/layer3/{symbol}/outcomes_per_event.csv",
        "bucket_stats": "__TMP__/layer3/{symbol}/bucket_stats.csv"
      }
    },
    "artifacts": {
      "enabled": true,
      "base_dir": "__TMP__/meta",
      "write_run_manifest": true,
      "write_metrics_summary": true
    }
  },
  "meta": {
    "fixture_id": "augmentation_l3_valid_outcomes_bucketing"
  }
}
