{
  "version": 262,
  "plan_kind": "sierra_research_engine.plan",
  "plan_io": {
    "format": "json",
    "encoding": "utf-8"
  },
  "universe": {
    "source": "inline",
    "symbols": [
      "ES",
      "NQ"
    ],
    "date_range": {
      "start": "2025-01-02",
      "end": "2025-01-02"
    }
  },
  "execution": {
    "worker_charts": [
      2
    ],
    "permissions": {
      "allow_filesystem_write": true
    },
    "backend": {
      "type": "sierra_chart",
      "sierra_chart": {}
    },
    "layer2": {
      "enabled": true,
      "mode": "authoritative_events",
      "require_final_bar": true,
      "align": {
        "mode": "last_completed"
      },
      "indicator_dag": {
        "nodes": {
          "always_true": {
            "kind": "param",
            "type": "bool",
            "value": true
          }
        }
      },
      "event_emitter": {
        "trigger_node": "always_true",
        "emit_mode": "on_true",
        "cooldown_bars": 0,
        "emit_columns": [
          {
            "name": "entry_price",
            "type": "float",
            "ref": "@bar.close"
          },
          {
            "name": "bar_datetime",
            "type": "datetime",
            "ref": "@bar.datetime"
          }
        ]
      }
    }
  },
  "studies": {
    "ema_fast": {
      "mode": "managed",
      "study_id": 1,
      "outputs": {
        "value": {
          "subgraph": 0
        }
      }
    }
  },
  "chains": {
    "main": {
      "steps": [
        {
          "kind": "emit",
          "from": "@study.ema_fast.value",
          "as": "ema"
        }
      ]
    }
  },
  "outputs": {
    "dataset": {
      "format": "csv",
      "path": "__TMP__/l2_date/{symbol}/authoritative.csv",
      "source": "layer2_event_emitter",
      "fields": [
        {
          "name": "symbol",
          "ref": "@event.symbol"
        },
        {
          "name": "bar_index",
          "ref": "@event.bar_index"
        },
        {
          "name": "entry_price",
          "ref": "@event.entry_price"
        },
        {
          "name": "bar_datetime",
          "ref": "@event.bar_datetime"
        }
      ]
    },
    "artifacts": {
      "enabled": true,
      "base_dir": "__TMP__/meta",
      "write_run_manifest": true,
      "write_metrics_summary": true
    }
  },
  "meta": {
    "fixture_id": "augmentation_l2_date_range_enforced"
  }
}
