{
  "version": 262,
  "plan_kind": "sierra_research_engine.plan",
  "plan_io": {
    "format": "json"
  },
  "compat": {
    "min_extension_api": 1,
    "allow_legacy_steps_without_kind": true
  },
  "meta": {
    "name": "Layer3 Bucket Eval Plan v2",
    "description": "Layer2 emits authoritative events from plan-bound study features; Layer3 computes outcomes and bucket-level EV.",
    "tags": ["layer2", "layer3", "bucket_eval", "authoritative", "rvol"]
  },
  "universe": {
    "source": "inline",
    "symbols": ["WORX"],
    "timeframe": "4h",
    "date_range": {
      "start": "2025-01-01",
      "end": "2026-02-21"
    }
  },
  "execution": {
    "controller_chart": 6,
    "worker_charts": [2],
    "permissions": {
      "allow_filesystem_write": true,
      "allow_network": false
    },
    "sentinel": {
      "enabled": true,
      "study_id": 6,
      "subgraph": 0,
      "slot": 6,
      "ready_value": 2.0,
      "timeout_cycles": 30
    },
    "backend": {
      "type": "sierra_chart",
      "sierra_chart": {
        "scheduler_mode": "serial",
        "layout_contract": {
          "enabled": true,
          "controller_chart": 6,
          "workers": [
            {
              "chart_number": 2,
              "required_studies": [
                {
                  "study_key": "rvol",
                  "require_outputs": ["sg1"]
                }
              ]
            }
          ],
          "readiness": {
            "mode": "sentinel"
          }
        }
      }
    },
    "layer2": {
      "enabled": true,
      "mode": "authoritative_events",
      "bar_basis": "close",
      "require_final_bar": true,
      "align": {
        "mode": "last_completed"
      },
      "indicator_dag": {
        "nodes": {
          "rvol_n": {
            "kind": "study_ref",
            "ref": "@study.rvol.sg1"
          },
          "threshold_n": {
            "kind": "param",
            "type": "float",
            "value": 7.0
          },
          "trigger_n": {
            "kind": "gt",
            "inputs": ["rvol_n", "threshold_n"]
          }
        }
      },
      "event_emitter": {
        "trigger_node": "trigger_n",
        "emit_mode": "on_true_edge",
        "cooldown_bars": 10,
        "emit_columns": [
          {
            "name": "entry_price",
            "type": "float",
            "ref": "@bar.close"
          },
          {
            "name": "bar_datetime",
            "type": "datetime",
            "ref": "@bar.datetime"
          },
          {
            "name": "rvol",
            "type": "float",
            "node": "rvol_n"
          }
        ]
      }
    }
  },
  "studies": {
    "rvol": {
      "mode": "bind",
      "chart_ref": "worker",
      "study_id": 6,
      "outputs": {
        "sg1": {
          "subgraph": 0,
          "field": "value"
        }
      }
    }
  },
  "chains": {
    "main": {
      "description": "Environment parity chain - binds RVOL SG1",
      "steps": [
        {
          "kind": "read",
          "read_refs": ["@study.rvol.sg1"]
        }
      ]
    }
  },
  "outputs": {
    "dataset": {
      "format": "csv",
      "path": "artifacts/{symbol}/layer2_authoritative.csv",
      "source": "layer2_event_emitter",
      "fields": [
        {
          "name": "symbol",
          "ref": "@event.symbol",
          "type": "string",
          "nullable": false
        },
        {
          "name": "bar_index",
          "ref": "@event.bar_index",
          "type": "int",
          "nullable": false
        },
        {
          "name": "bar_datetime",
          "ref": "@event.bar_datetime",
          "type": "datetime",
          "nullable": false
        },
        {
          "name": "entry_price",
          "ref": "@event.entry_price",
          "type": "float",
          "nullable": false
        },
        {
          "name": "rvol",
          "ref": "@event.rvol",
          "type": "float",
          "nullable": false
        }
      ]
    },
    "layer3": {
      "enabled": true,
      "mode": "bucket_eval",
      "inputs": {
        "layer2_authoritative_csv": "artifacts/{symbol}/layer2_authoritative.csv"
      },
      "eligibility": {
        "emit_for_all_eligible_buckets": true,
        "rules": [
          {
            "id": "min_samples",
            "scope": "bucket",
            "field": "n_trades",
            "op": ">=",
            "value": 20
          },
          {
            "id": "ev_floor",
            "scope": "bucket",
            "field": "EV",
            "op": ">=",
            "value": 0.0
          }
        ],
        "quantile_sample_gates": []
      },
      "rr_menu": {
        "risk_quantiles": [0.8, 0.9],
        "reward_quantiles": [0.5, 0.8],
        "pairing": "cartesian",
        "row_rules": []
      },
      "normalization": {
        "mode": "pct_of_price",
        "entry_price_field": "entry_price",
        "emit_raw_price_columns": true,
        "emit_pct_columns": true
      },
      "units_contract": {
        "signal_bucket_units": "signal:rvol",
        "mae_units": "pct",
        "mfe_units": "pct",
        "enforce_no_bucket_clamp": true
      },
      "bucketing": {
        "dimensions": [
          {
            "field": "rvol",
            "method": "quantile",
            "q": [0.25, 0.5, 0.75]
          }
        ]
      },
      "outcomes": {
        "enabled": true,
        "entry_price_field": "entry_price",
        "horizons_bars": [5, 10, 15, 20],
        "sides": ["long", "short"],
        "horizon": {
          "type": "bars",
          "value": 5
        },
        "price_fields": {
          "high": "high",
          "low": "low",
          "close": "close"
        },
        "cost_model": {
          "type": "none"
        }
      },
      "metrics": {
        "per_bucket": {
          "emit": [
            "n_trades",
            "EV",
            "mfe_p50",
            "mfe_p80",
            "mfe_p90",
            "mfe_p95",
            "mfa_p50",
            "mfa_p25",
            "mfa_p10",
            "mfa_p05"
          ]
        }
      },
      "artifacts": {
        "rr_buckets": "artifacts/{symbol}/layer3_rr_buckets.csv",
        "decision_audit": "artifacts/{symbol}/layer3_decision_audit.csv",
        "outcomes_per_event": "artifacts/{symbol}/layer3_outcomes_per_event.csv",
        "bucket_stats": "artifacts/{symbol}/layer3_bucket_stats.csv"
      }
    },
    "artifacts": {
      "enabled": true,
      "base_dir": "artifacts",
      "write_run_manifest": true,
      "write_metrics_summary": true
    }
  }
}
